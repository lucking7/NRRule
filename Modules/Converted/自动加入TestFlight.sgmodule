#!name=自动加入TestFlight
#!desc=自动监控TestFlight名额，一旦有新的名额即刻加入。
#!author=奶思[https://github.com/fmz200], DecoAri[https://github.com/DecoAri], xream[https://github.com/xream]
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/TestFlight.png
#!category=🚫 AD Block
#!openUrl=https://apps.apple.com/app/id899247664
#!category=定时任务
#!loon_version=3.2.4(787)
#!homepage=https://hub.kelee.one
#!date=2025-11-08 03:27:30
#!arguments=CaptureAccountToken:#,RunTask:#,RunMonitor:#,TaskCron:"0 0/2 * * * ?",TaskMonitor:"0 * * * * ?"
#!arguments-desc=CaptureAccountToken: 捕获账号令牌\n此开关控制插件是否捕获账户令牌\n\nRunTask: 自动加入TF\n此开关控制是否启动定时任务\n\nRunMonitor: 监控TF位置\n此开关控制是否启动定时任务\n\nTaskCron: 加入TF定时参数\n这里需要输入符合CRON表达式的参数\n\nTaskMonitor: 监控TF定时参数\n这里需要输入符合CRON表达式的参数

[Script]
{{{CaptureAccountToken}}}获取账号令牌 = type=http-request, pattern=^https?:\/\/testflight\.apple\.com\/v3\/accounts\/.*\/apps$, script-path=https://nrrule.pages.dev/Scripts/CaptureAccountToken.js

{{{RunTask}}}自动加入TF = type=cron, cronexp="{{{TaskCron}}}", script-path=https://nrrule.pages.dev/Scripts/AutoJoinTF.js, timeout=600

{{{RunMonitor}}}监控TF位置 = type=cron, cronexp="{{{TaskMonitor}}}", script-path=https://nrrule.pages.dev/Scripts/AutoMonitorTF.js, timeout=30

